# Control plane
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://newsletters:change-me@localhost:5433/avila_newsletters
ADMIN_API_TOKEN=replace-with-a-long-random-token

# Delivery is disabled unless this is the literal value true.
DELIVERY_ENABLED=false

# n8n delivery webhook. Keep the secret out of version control.
N8N_DELIVERY_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_INGEST_TOKEN=
WORKER_POLL_MS=5000
# Reclaim dispatching items after a worker crash (5 minutes by default).
WORKER_LOCK_TIMEOUT_MS=300000

# Optional legacy MailerSend template sync. This token must have
# Templates: Full access and Email: No access.
MAILERSEND_TEMPLATE_API_TOKEN=

# Optional. When set, templates are associated with and matched within this domain.
MAILERSEND_DOMAIN_ID=
